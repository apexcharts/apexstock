    "@angular/compiler-cli": "^18.2.13",
    "@angular/core": "^18.2.13",
    "jsdom": "^25.0.1",
    "ng-packagr": "^18.2.1",
    "rxjs": "^7.8.1",
    "typescript": "~5.5.4",
    "vitest": "^2.1.8",
    "zone.js": "~0.14.10"
