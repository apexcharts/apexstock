{
  "name": "react-apexstock",
  "version": "0.1.0",
  "description": "React component wrapper for ApexStock (financial charting on top of ApexCharts)",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "apexstock",
    "apexcharts",
    "react",
    "stock-chart",
    "candlestick",
    "financial-charts"
  ],
  "license": "see LICENSE in LICENSE",
  "peerDependencies": {
    "apexstock": "^0.2.0",
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
