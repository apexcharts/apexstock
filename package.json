{
  "name": "apexstock",
  "version": "0.1.0",
  "type": "module",
  "description": "An extension library for ApexCharts focusing on stock charts",
  "main": "dist/apexstock.min.js",
  "module": "dist/apexstock.esm.js",
  "types": "dist/types/ApexStock.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/ApexStock.d.ts",
      "import": "./dist/apexstock.esm.js",
      "require": "./dist/apexstock.umd.js",
      "default": "./dist/apexstock.umd.js"
    },
    "./apexstock.css": "./dist/apexstock.css",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "dependencies": {
    "apex-commons": "^0.1.0"
  },
  "scripts": {
    "build": "rollup -c && npm run build:types",
    "build:types": "tsc -p tsconfig.json",
    "dev": "rollup -c -w --bundleConfigAsCjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "apexcharts",
    "charts",
    "stock",
    "financial"
  ],
  "browserslist": [
    "> 0.25%",
    "not dead"
  ],
  "license": "see LICENSE in LICENSE",
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/preset-env": "^7.23.2",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.4",
    "@rollup/plugin-node-resolve": "^15.2.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "core-js": "^3.33.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "rollup": "^3.29.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "apexcharts": "^5.15.0"
  }
}
