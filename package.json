{
  "name": "apexstock",
  "version": "0.2.0",
  "type": "module",
  "description": "An extension library for ApexCharts focusing on stock charts",
  "main": "dist/apexstock.cjs",
  "module": "dist/apexstock.esm.js",
  "types": "dist/types/ApexStock.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/ApexStock.d.ts",
      "import": "./dist/apexstock.esm.js",
      "require": "./dist/apexstock.cjs",
      "default": "./dist/apexstock.cjs"
    },
    "./apexstock.css": "./dist/apexstock.css",
    "./theme-template.css": "./dist/themes/apexstock-theme-template.css",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "THEMING.md"
  ],
  "dependencies": {
    "apex-commons": "^0.1.0"
  },
  "scripts": {
    "build": "rollup -c && npm run build:types",
    "build:types": "tsc -p tsconfig.json",
    "dev": "rollup -c -w --bundleConfigAsCjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "packages:install": "node scripts/run-all.mjs install",
    "packages:build": "node scripts/run-all.mjs build",
    "packages:typecheck": "node scripts/run-all.mjs typecheck",
    "packages:test": "node scripts/run-all.mjs test"
  },
  "keywords": [
    "apexcharts",
    "charts",
    "stock",
    "financial"
  ],
  "browserslist": [
    "> 0.25%",
    "not dead"
  ],
  "license": "see LICENSE in LICENSE",
  "resolutions": {
    "undici": "^7.28.0",
    "picomatch": "^4.0.4",
    "glob/minimatch": "^5.1.7",
    "glob/minimatch/brace-expansion": "^2.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.58.2",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.2.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "core-js": "^3.33.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "rollup": "^3.30.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "apexcharts": "^5.15.0"
  }
}
